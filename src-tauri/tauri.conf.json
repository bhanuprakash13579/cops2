{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "COPS",
  "version": "3.0.7",
  "identifier": "gov.in.customs.cops",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "COPS — Customs Offence Processing System",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "maximized": true,
        "visible": false,
        "backgroundColor": "#f8fafc"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDIzQjc2QzU5QjU3MEQzOEEKUldTSzAzQzFXV3kzSTM1OGJ3QkpWbUI4djZieU1icjBxSjRDSHZhNmdra1c0UHYrVnoxZW9PUkgK",
      "endpoints": [
        "https://github.com/bhanuprakash13579/cops2/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0",
          "libayatana-appindicator3-1",
          "librsvg2-2"
        ]
      }
    }
  }
}
